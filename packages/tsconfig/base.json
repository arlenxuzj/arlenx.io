{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Default",
  "compilerOptions": {
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "allowJs": true,
    "noEmit": true,
    "composite": false,
    "preserveWatchOutput": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "dist", "build"]
}
