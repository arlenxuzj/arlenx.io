{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Next.js",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES5",
    "module": "ESNext",
    "moduleResolution": "Node",

    "lib": ["dom", "dom.iterable", "esnext"],

    "incremental": true,

    "jsx": "preserve"
  },
  "include": ["next-env.d.ts"],
  "exclude": ["node_modules"]
}
