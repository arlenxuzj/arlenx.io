{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React Library",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",

    "lib": ["DOM", "DOM.Iterable", "ESNext"],

    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx"
  }
}
